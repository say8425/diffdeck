{
	"name": "diffdeck-monorepo",
	"private": true,
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"type": "module",
	"scripts": {
		"typecheck": "tsc --noEmit -p tsconfig.base.json",
		"lint": "oxlint packages/ apps/ bin/",
		"format": "oxfmt packages/ apps/ bin/",
		"format:check": "oxfmt --check packages/ apps/ bin/",
		"test": "bun test"
	},
	"devDependencies": {
		"@types/bun": "1.3.14",
		"oxfmt": "0.57.0",
		"oxlint": "1.72.0",
		"typescript": "6.0.3"
	}
}
